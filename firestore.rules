rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email', 'xp', 'streak']) &&
        request.resource.data.xp is int &&
        request.resource.data.streak is int;
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'streak', 'lastActive', 'completedLessons', 'level']);
    }

    // Lessons Collection (Public Read, Admin Write)
    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if false; // Only via console/admin for now
    }

    // Streak Logs
    match /users/{userId}/streaks/{date} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidId(date);
    }
  }
}
